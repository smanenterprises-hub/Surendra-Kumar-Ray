CSS
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins,sans-serif;
scroll-behavior:smooth;
}

body{
background:#0b0b0b;
color:white;
}

header{
position:fixed;
width:100%;
top:0;
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 8%;
background:black;
z-index:1000;
}

.logo{
font-size:30px;
font-weight:700;
color:#d4af37;
}

nav a{
color:white;
text-decoration:none;
margin-left:25px;
font-weight:500;
transition:.3s;
}

nav a:hover{
color:#d4af37;
}

.hero{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
background:
linear-gradient(rgba(0,0,0,.75),
rgba(0,0,0,.75)),
url('project1.jpg');
background-size:cover;
background-position:center;
}

.hero h1{
font-size:75px;
color:#d4af37;
}

.hero p{
font-size:24px;
margin:15px 0;
}

.btn{
padding:14px 35px;
background:#d4af37;
color:black;
text-decoration:none;
font-weight:bold;
border-radius:5px;
}

section{
padding:100px 8%;
}

.title{
text-align:center;
font-size:42px;
margin-bottom:50px;
color:#d4af37;
}

.about-container{
display:grid;
grid-template-columns:1fr 1fr;
gap:40px;
}

.about-text h3{
font-size:32px;
color:#d4af37;
margin-bottom:20px;
}

.stats{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:20px;
}

.card{
background:#171717;
padding:30px;
text-align:center;
border-radius:10px;
}

.card h2{
color:#d4af37;
}

.services{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.service-card{
background:#171717;
padding:40px;
text-align:center;
border-radius:10px;
transition:.4s;
}

.service-card:hover{
transform:translateY(-10px);
}

.service-card i{
font-size:40px;
color:#d4af37;
margin-bottom:20px;
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:20px;
}

.gallery img{
width:100%;
height:250px;
object-fit:cover;
border-radius:10px;
transition:.4s;
}

.gallery img:hover{
transform:scale(1.05);
}

.contact-box{
max-width:700px;
margin:auto;
text-align:center;
}

form{
display:flex;
flex-direction:column;
gap:15px;
margin-top:25px;
}

input,
textarea{
padding:15px;
background:#171717;
border:1px solid #444;
color:white;
border-radius:5px;
}

button{
padding:15px;
border:none;
background:#d4af37;
font-weight:bold;
cursor:pointer;
}

footer{
background:black;
padding:20px;
text-align:center;
}

.whatsapp{
position:fixed;
bottom:20px;
right:20px;
width:60px;
height:60px;
background:#25D366;
border-radius:50%;
display:flex;
justify-content:center;
align-items:center;
color:white;
font-size:30px;
text-decoration:none;
}

.reveal{
opacity:0;
transform:translateY(60px);
transition:1s;
}

.reveal.active{
opacity:1;
transform:translateY(0);
}

@media(max-width:768px){

.hero h1{
font-size:45px;
}

.about-container{
grid-template-columns:1fr;
}

.stats{
grid-template-columns:1fr;
}

nav{
display:none;
}

}
JAVA SCRIPT 
const reveals = document.querySelectorAll(".reveal");

window.addEventListener("scroll", () => {

reveals.forEach((element) => {

const windowHeight = window.innerHeight;

const revealTop =
element.getBoundingClientRect().top;

if(revealTop < windowHeight - 100){
element.classList.add("active");
}

});

});
